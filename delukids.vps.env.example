# Environment file for VPS deployment (place at /root/delukids.env)
# Do NOT commit real secrets.

# Public (used for Vite build args + backend auth proxy)
VITE_SUPABASE_URL=https://<your-supabase-host>
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-jwt>
VITE_MP_PUBLIC_KEY=APP_USR-<your-mp-public-key>
VITE_ADYEN_CLIENT_KEY=ADYEN_CLIENT_KEY
VITE_ADYEN_ENV=test

# App
PUBLIC_BASE_URL=https://loja.arxsolutions.cloud
CORS_ORIGINS=https://loja.arxsolutions.cloud,http://localhost:5173

# Admin
ADMIN_EMAILS=you@example.com
ADMIN_USER_IDS=

# Secrets (used to create Swarm secrets)
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-<mp-access-token>
ADYEN_API_KEY=<adyen-api-key>
ADYEN_MERCHANT_ACCOUNT=<adyen-merchant-account>

# Random secret used to validate Mercado Pago webhook requests.
# Generate with: openssl rand -hex 32
MP_WEBHOOK_SECRET=<random-string>

# Integrations (optional)
N8N_TRACKING_WEBHOOK_URL=
N8N_ORDER_STATUS_WEBHOOK_URL=
N8N_NEW_ORDER_WEBHOOK_URL=
N8N_NEWSLETTER_WEBHOOK_URL=
